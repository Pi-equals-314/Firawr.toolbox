class AudioConverterPanel(ctk.CTkFrame):
    def __init__(self, master):
        super().__init__(master, fg_color=BG_PANEL, corner_radius=0)
        self._build()

    def _build(self):
        _panel_header(self, "🎵", "Audio Converter",
                      "Convert any audio file between formats using pydub.")

        card = _card(self, "Conversion Settings")

        # File picker
        row1 = ctk.CTkFrame(card, fg_color="transparent")
        row1.pack(fill="x", padx=16, pady=(8, 4))
        ctk.CTkLabel(row1, text="Source File", font=("Consolas", 11),
                     text_color=TEXT_SEC, width=100, anchor="w").pack(side="left")
        self.file_var = ctk.StringVar()
        ctk.CTkEntry(row1, textvariable=self.file_var, width=320,
                     fg_color=BG_INPUT, border_color=BORDER,
                     font=("Consolas", 11)).pack(side="left", padx=(0, 8))
        ctk.CTkButton(row1, text="Browse", width=80, fg_color=BG_CARD,
                      hover_color=BORDER, border_width=1, border_color=BORDER,
                      command=self._browse).pack(side="left")

        # Format selector
        row2 = ctk.CTkFrame(card, fg_color="transparent")
        row2.pack(fill="x", padx=16, pady=(4, 12))
        ctk.CTkLabel(row2, text="Target Format", font=("Consolas", 11),
                     text_color=TEXT_SEC, width=100, anchor="w").pack(side="left")
        self.fmt_var = ctk.StringVar(value="mp3")
        ctk.CTkComboBox(row2, variable=self.fmt_var,
                        values=["mp3","wav","flac","ogg","aac","m4a","wma"],
                        width=140, fg_color=BG_INPUT, border_color=BORDER,
                        button_color=GREEN, button_hover_color=GREEN_HOVER,
                        font=("Consolas", 11)).pack(side="left")

        self.status = _log_box(self)

        ctk.CTkButton(self, text="🔄  Convert", fg_color=GREEN,
                      hover_color=GREEN_HOVER, text_color="#000",
                      font=("Consolas", 13, "bold"),
                      command=self._convert).pack(pady=12)

    def _browse(self):
        path = filedialog.askopenfilename(
            filetypes=[("Audio files","*.mp3 *.wav *.flac *.ogg *.aac *.m4a *.wma *.aiff"),
                       ("All files","*.*")])
        if path: self.file_var.set(path)

    def _convert(self):
        def task():
            try:
                from pydub import AudioSegment
            except ImportError:
                self._log("✗  pip install pydub"); return
            src = self.file_var.get().strip()
            frm = self.fmt_var.get().strip().lower()
            if not src:
                self._log("✗  No file selected."); return
            if not os.path.isfile(src):
                self._log(f"✗  File not found: {src}"); return
            ext = src.rsplit(".", 1)[-1].lower()
            if ext == frm:
                self._log("⚠  Already in that format."); return
            newpath = src[:-(len(ext))] + frm
            self._log(f"Converting {ext} → {frm} …")
            try:
                AudioSegment.from_file(src, ext).export(newpath, format=frm)
                self._log(f"✓  Saved → {newpath}")
            except Exception as e:
                self._log(f"✗  {e}")
        threading.Thread(target=task, daemon=True).start()

    def _log(self, msg):
        self.status.configure(state="normal")
        self.status.insert("end", msg + "\n")
        self.status.see("end")
        self.status.configure(state="disabled")


