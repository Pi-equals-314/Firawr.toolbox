def _card(parent, label):
    outer = ctk.CTkFrame(parent, fg_color=BG_CARD, corner_radius=10,
                          border_width=1, border_color=BORDER)
    outer.pack(fill="x", padx=32, pady=(0, 12))
    ctk.CTkLabel(outer, text=label, font=("Consolas", 10),
                 text_color=TEXT_MUTED).pack(anchor="w", padx=16, pady=(10, 0))
    return outer


def _log_box(parent):
    frame = ctk.CTkFrame(parent, fg_color=BG_CARD, corner_radius=10,
                          border_width=1, border_color=BORDER)
    frame.pack(fill="both", expand=True, padx=32, pady=(0, 0))
    ctk.CTkLabel(frame, text="Output", font=("Consolas", 10),
                 text_color=TEXT_MUTED).pack(anchor="w", padx=14, pady=(8, 0))
    box = ctk.CTkTextbox(frame, fg_color="transparent", font=("Consolas", 11),
                          text_color=GREEN, state="disabled",
                          scrollbar_button_color=BORDER)
    box.pack(fill="both", expand=True, padx=10, pady=(0, 10))
    return box


