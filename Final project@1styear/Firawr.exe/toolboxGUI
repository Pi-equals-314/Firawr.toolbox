        # ── Result cards ──────────────────────────────────────────────────
        results = ctk.CTkFrame(self, fg_color="transparent")
        results.pack(fill="both", expand=True, padx=32, pady=(0, 12))
        results.columnconfigure((0, 1), weight=1, uniform="col")

        def _text_card(parent, col, label):
            card = ctk.CTkFrame(parent, fg_color=BG_CARD, corner_radius=10,
                                border_width=1, border_color=BORDER)
            card.grid(row=0, column=col, sticky="nsew", padx=(0 if col else 0, 8 if col == 0 else 0))
            ctk.CTkLabel(card, text=label, font=("Consolas", 10),
                         text_color=TEXT_MUTED).pack(anchor="w", padx=14, pady=(8, 0))
            box = ctk.CTkTextbox(card, fg_color="transparent", font=("Consolas", 12),
                                  text_color=TEXT_PRI, state="disabled",
                                  scrollbar_button_color=BORDER, wrap="word")
            box.pack(fill="both", expand=True, padx=10, pady=(0, 10))
            return box

        self.transcript_box  = _text_card(results, 0, "Transcription")
        self.translation_box = _text_card(results, 1, "Translation")

        # ── Status log ────────────────────────────────────────────────────
        self.status = _log_box(self)

        # ── Buttons ───────────────────────────────────────────────────────
        btn_row = ctk.CTkFrame(self, fg_color="transparent")
        btn_row.pack(pady=12)
        ctk.CTkButton(btn_row, text="🎙  Listen & Translate", fg_color=GREEN,
                      hover_color=GREEN_HOVER, text_color="#000",
                      font=("Consolas", 13, "bold"),
                      command=self._listen).pack(side="left", padx=8)
        ctk.CTkButton(btn_row, text="🗑  Clear", width=90, fg_color=BG_CARD,
                      hover_color=BORDER, border_width=1, border_color=BORDER,
                      text_color=TEXT_SEC, font=("Consolas", 12),
                      command=self._clear).pack(side="left", padx=4)

    # ── Core logic ────────────────────────────────────────────────────────

    def _listen(self):
        def task():
            try:
                import speech_recognition as sr
            except ImportError:
                self._log("✗  pip install SpeechRecognition"); return

            try:
                from deep_translator import GoogleTranslator
            except ImportError:
                self._log("✗  pip install deep-translator"); return

            src_name = self.src_lang_var.get()
            tgt_name = self.tgt_lang_var.get()
            src_code = self.LANGUAGES.get(src_name, "en")
            tgt_code = self.LANGUAGES.get(tgt_name, "fr")

            self._log(f"🎙  Recording in {src_name} (8 s)…")
            try:
                samplerate = 44100
                recording = sd.rec(int(8 * samplerate), samplerate=samplerate,
                                   channels=1, dtype='int16')
                sd.wait()
                temp_wav = "temp_translate.wav"
                sf.write(temp_wav, recording, samplerate)
            except Exception as e:
                self._log(f"✗  Recording error: {e}"); return

            r = sr.Recognizer()
            try:
                with sr.AudioFile(temp_wav) as source:
                    audio = r.record(source)
                query = r.recognize_google(audio, language=src_code)
            except sr.UnknownValueError:
                self._log("✗  Could not understand audio.")
                if os.path.exists(temp_wav): os.remove(temp_wav)
                return
            except sr.RequestError as e:
                self._log(f"✗  Google API error: {e}")
                if os.path.exists(temp_wav): os.remove(temp_wav)
                return
            except Exception as e:
                self._log(f"✗  {e}")
                if os.path.exists(temp_wav): os.remove(temp_wav)
                return

            self._set_text(self.transcript_box, query)
            self._log(f"✓  Transcribed: {query}")
            self._log(f"Translating to {tgt_name}…")

            try:
                result_text = GoogleTranslator(source=src_code, target=tgt_code).translate(query)
                self._set_text(self.translation_box, result_text)
                self._log(f"✓  Translation: {result_text}")
            except Exception as e:
                self._log(f"✗  Translation error: {e}")

            if os.path.exists(temp_wav):
                os.remove(temp_wav)

        threading.Thread(target=task, daemon=True).start()

    def _clear(self):
        for box in (self.transcript_box, self.translation_box):
            box.configure(state="normal")
            box.delete("1.0", "end")
            box.configure(state="disabled")
        self.status.configure(state="normal")
        self.status.delete("1.0", "end")
        self.status.configure(state="disabled")

    def _set_text(self, box, text):
        box.configure(state="normal")
        box.delete("1.0", "end")
        box.insert("end", text)
        box.configure(state="disabled")

    def _log(self, msg):
        self.status.configure(state="normal")
        self.status.insert("end", msg + "\n")
        self.status.see("end")
        self.status.configure(state="disabled")


