                    "Utilities","Entertainment","Health","Other"],
            width=180, fg_color=BG_INPUT, border_color=BORDER,
            button_color=GREEN, button_hover_color=GREEN_HOVER,
            font=("Consolas", 11))
        self.cat_cb.pack(side="left", padx=(0, 16))
        ctk.CTkButton(cat_row, text="+ Add Transaction", fg_color=GREEN,
                      hover_color=GREEN_HOVER, text_color="#000",
                      font=("Consolas", 12, "bold"),
                      command=self._add).pack(side="left")

        tbl_frame = ctk.CTkFrame(self, fg_color=BG_CARD, corner_radius=10,
                                  border_width=1, border_color=BORDER)
        tbl_frame.pack(fill="both", expand=True, padx=32, pady=(0, 8))

        import tkinter.ttk as ttk
        style = ttk.Style()
        style.theme_use("clam")
        style.configure("Firawr.Treeview",
                        background=BG_CARD, fieldbackground=BG_CARD,
                        foreground=TEXT_PRI, rowheight=28,
                        font=("Consolas", 11), borderwidth=0)
        style.configure("Firawr.Treeview.Heading",
                        background=BG_INPUT, foreground=GREEN,
                        font=("Consolas", 11, "bold"), relief="flat")
        style.map("Firawr.Treeview", background=[("selected", GREEN_DIM)])

        cols = ("ID","Date","Description","Amount","Category")
        self.tree = ttk.Treeview(tbl_frame, columns=cols, show="headings",
                                  style="Firawr.Treeview", height=10)
        widths = {"ID":40,"Date":100,"Description":260,"Amount":100,"Category":120}
        for col in cols:
            self.tree.heading(col, text=col)
            self.tree.column(col, width=widths[col], anchor="w")
        sb = ttk.Scrollbar(tbl_frame, orient="vertical", command=self.tree.yview)
        self.tree.configure(yscrollcommand=sb.set)
        self.tree.pack(side="left", fill="both", expand=True, padx=2, pady=2)
        sb.pack(side="right", fill="y")

        btn_row = ctk.CTkFrame(self, fg_color="transparent")
        btn_row.pack(pady=(0, 16))
        ctk.CTkButton(btn_row, text="🗑  Delete Selected", fg_color="#2a1515",
                      hover_color="#3d1f1f", border_width=1, border_color="#5a2020",
                      text_color="#e74c3c", font=("Consolas", 12),
                      command=self._delete).pack()

    def _add(self):
        d    = self.date_e.get().strip()
        desc = self.desc_e.get().strip()
        amt  = self.amt_e.get().strip()
        cat  = self.cat_cb.get()
        if not all([d, desc, amt, cat]):
            messagebox.showwarning("Missing fields", "Fill in all fields."); return
        try: amt_f = float(amt)
        except ValueError:
            messagebox.showerror("Invalid", "Amount must be a number."); return
        self.conn.cursor().execute(
            "INSERT INTO transactions (date,description,amount,category) VALUES (?,?,?,?)",
            (d, desc, amt_f, cat))
        self.conn.commit()
        for e in (self.date_e, self.desc_e, self.amt_e): e.delete(0, "end")
        self.cat_cb.set("")
        self._refresh()

    def _delete(self):
        sel = self.tree.selection()
        if not sel: messagebox.showwarning("None selected","Pick a row."); return
        tx_id = self.tree.item(sel[0])["values"][0]
        self.conn.cursor().execute("DELETE FROM transactions WHERE id=?", (tx_id,))
        self.conn.commit()
        self._refresh()

    def _refresh(self):
        for row in self.tree.get_children(): self.tree.delete(row)
        cur = self.conn.cursor()
        cur.execute("SELECT * FROM transactions ORDER BY date DESC")
        for row in cur.fetchall(): self.tree.insert("", "end", values=row)
        cur.execute("SELECT COALESCE(SUM(amount),0) FROM transactions WHERE amount>0")
        income = cur.fetchone()[0]
        cur.execute("SELECT COALESCE(SUM(amount),0) FROM transactions WHERE amount<0")
        expense = abs(cur.fetchone()[0])
        balance = income - expense
        self.bal_lbl.configure(text=f"Balance  ${balance:,.2f}",
                                text_color=GREEN if balance >= 0 else "#e74c3c")
        self.inc_lbl.configure(text=f"Income  ${income:,.2f}")
        self.exp_lbl.configure(text=f"Expenses  ${expense:,.2f}")


