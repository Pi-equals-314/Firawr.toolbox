class FirawrApp(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.title("Firawr")
        self.geometry("1120x720")
        self.minsize(900, 600)
        self.configure(fg_color=BG_DARK)

        self._panels   = {}
        self._nav_btns = {}
        self._active   = None

        self._build_sidebar()
        self._build_content()
        self._select("Dashboard")

    # ── Sidebar ───────────────────────────────────────────────────────────
    def _build_sidebar(self):
        sb = ctk.CTkFrame(self, width=220, fg_color=SIDEBAR_BG,
                           corner_radius=0, border_width=0)
        sb.pack(side="left", fill="y")
        sb.pack_propagate(False)

        logo_frame = ctk.CTkFrame(sb, fg_color="transparent")
        logo_frame.pack(fill="x", padx=24, pady=(28, 6))
        ctk.CTkLabel(logo_frame, text="Firawr",
                     font=("Georgia", 26, "bold"),
                     text_color=GREEN).pack(anchor="w")
        ctk.CTkLabel(logo_frame, text="Python Toolbox",
                     font=("Consolas", 10),
                     text_color=TEXT_MUTED).pack(anchor="w")

        ctk.CTkFrame(sb, height=1, fg_color=BORDER).pack(fill="x", padx=16, pady=(12, 20))

        nav = ctk.CTkFrame(sb, fg_color="transparent")
        nav.pack(fill="x", padx=12)

        for label, icon, _ in TOOL_REGISTRY:
            btn = ctk.CTkButton(
                nav,
                text=f"  {icon}   {label}",
                anchor="w",
                height=40,
                fg_color="transparent",
                hover_color=BG_CARD,
                text_color=TEXT_SEC,
                font=("Consolas", 12),
                corner_radius=8,
                command=lambda l=label: self._select(l),
            )
            btn.pack(fill="x", pady=2)
            self._nav_btns[label] = btn

        ctk.CTkLabel(sb, text="v1.1  ·  add tools in TOOL_REGISTRY",
                     font=("Consolas", 9), text_color=TEXT_MUTED,
                     wraplength=190).pack(side="bottom", pady=20, padx=16)

    # ── Content area ──────────────────────────────────────────────────────
    def _build_content(self):
        self._content = ctk.CTkFrame(self, fg_color=BG_PANEL, corner_radius=0)
        self._content.pack(side="left", fill="both", expand=True)

    def _select(self, label):
        if self._active and self._active in self._nav_btns:
            self._nav_btns[self._active].configure(
                fg_color="transparent", text_color=TEXT_SEC)
        if self._active and self._active in self._panels:
            self._panels[self._active].pack_forget()

        self._active = label
        self._nav_btns[label].configure(fg_color=BG_CARD, text_color=GREEN)

        if label not in self._panels:
            panel_cls = next(pc for l, _, pc in TOOL_REGISTRY if l == label)
            self._panels[label] = panel_cls(self._content)

        self._panels[label].pack(fill="both", expand=True)


