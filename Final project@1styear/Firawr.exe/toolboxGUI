        cat_row.pack(fill="x", padx=16, pady=(0, 12))
        ctk.CTkLabel(cat_row, text="Category", font=("Consolas", 11),
                     text_color=TEXT_SEC, width=80, anchor="w").pack(side="left")
        self.cat_cb = ctk.CTkComboBox(cat_row,
