class _CodeReviewerCore:
    """
    Pure-logic code reviewer — no GUI dependencies.
    Fixed from original: pycodestyle is run against a temp file (it expects
    a real path, not a string), and the undefined-var heuristic is preserved
    as-is from the original.
    """

    def __init__(self):
        self.feedback = []

    # ── public entry points ────────────────────────────────────────────────

    def analyze_file(self, file_path: str):
        try:
            with open(file_path, "r", encoding="utf-8") as fh:
                code = fh.read()
        except OSError as e:
            self.feedback.append(f"✗  Cannot open file: {e}")
            return
        self.analyze_code(code)

    def analyze_code(self, code: str):
        self.feedback.clear()
        try:
            tree = ast.parse(code)
        except SyntaxError as e:
            self.feedback.append(f"SyntaxError — line {e.lineno}: {e.msg}")
            return

        self._check_missing_docstrings(tree)
        self._check_undefined_vars(tree)
        self._check_code_style(code)
        self._check_comments(code)

    # ── checks ────────────────────────────────────────────────────────────

    def _check_missing_docstrings(self, tree):
        """Flag functions that have no docstring (original called this 'indentation')."""
        for node in ast.walk(tree):
            if isinstance(node, ast.FunctionDef):
                first = node.body[0] if node.body else None
                has_doc = (
                    first and
                    isinstance(first, ast.Expr) and
                    isinstance(first.value, ast.Constant) and
                    isinstance(first.value.value, str)
                )
                if not has_doc:
                    self.feedback.append(
                        f"⚠  Function '{node.name}' (line {node.lineno}) has no docstring."
                    )

    def _check_undefined_vars(self, tree):
        """
        Heuristic: collect names that appear in Load context before any
        Store context in module scope.  Builtins and common globals are
        excluded to cut noise.
        """
        BUILTINS = set(dir(__builtins__)) if isinstance(__builtins__, dict) \
                   else set(dir(__builtins__))
        stored  = set()
        suspect = []
        for node in ast.walk(tree):
            if isinstance(node, ast.Name):
                if isinstance(node.ctx, ast.Store):
                    stored.add(node.id)
                elif isinstance(node.ctx, ast.Load):
                    if node.id not in stored and node.id not in BUILTINS:
                        suspect.append((node.id, getattr(node, "lineno", "?")))
        seen = set()
        for name, lineno in suspect:
            if name not in seen and name not in stored:
                self.feedback.append(
                    f"⚠  '{name}' (line {lineno}) may be used before assignment."
                )
                seen.add(name)

    def _check_code_style(self, code: str):
        """Write code to a temp file so pycodestyle can analyse it properly."""
        try:
            import pycodestyle
        except ImportError:
            self.feedback.append("ℹ  pip install pycodestyle  to enable style checks.")
            return
        with tempfile.NamedTemporaryFile(mode="w", suffix=".py",
                                         delete=False, encoding="utf-8") as tmp:
            tmp.write(code)
            tmp_path = tmp.name
        try:
            style  = pycodestyle.StyleGuide(quiet=True)
            result = style.check_files([tmp_path])
            if result.total_errors:
                self.feedback.append(
                    f"✗  pycodestyle found {result.total_errors} style issue(s) "
                    f"(E1xx indentation, E2xx whitespace, E3xx blank lines, etc.)."
                )
            else:
                self.feedback.append("✓  pycodestyle: no style issues found.")
        finally:
            os.unlink(tmp_path)

    def _check_comments(self, code: str):
        for i, line in enumerate(code.splitlines(), 1):
            stripped = line.strip()
            if stripped.startswith("#"):
                # bare '#' or '#X' with no space
                if len(stripped) == 1 or stripped[1] != " ":
                    self.feedback.append(
                        f"⚠  Comment style (line {i}): use '# text' not '{stripped[:10]}'"
                    )

    def get_feedback(self):
        return self.feedback


