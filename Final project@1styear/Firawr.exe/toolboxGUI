    def _load_file(self):
        path = self.file_var.get().strip()
        if not path or not os.path.isfile(path):
            messagebox.showerror("Error", "Select a valid .py file first."); return
        with open(path, "r", encoding="utf-8") as fh:
            code = fh.read()
        self.editor.delete("1.0", "end")
        self.editor.insert("end", code)
        self._log(f"✓  Loaded: {path}")

    def _run_review(self):
        def task():
            code = self.editor.get("1.0", "end").strip()
            if not code:
                self._log("✗  Editor is empty."); return
            self._log("─" * 48)
            self._log("Running review…")
            self._reviewer.analyze_code(code)
            feedback = self._reviewer.get_feedback()
            if not feedback:
                self._log("✓  All checks passed — no issues found!")
            else:
                for line in feedback:
                    self._log(f"  {line}")
            self._log(f"─" * 48)
            self._log(f"Done — {len(feedback)} finding(s).")
        threading.Thread(target=task, daemon=True).start()

    def _clear(self):
        self.editor.delete("1.0", "end")
        self.status.configure(state="normal")
        self.status.delete("1.0", "end")
        self.status.configure(state="disabled")

    def _log(self, msg):
        self.status.configure(state="normal")
        self.status.insert("end", msg + "\n")
        self.status.see("end")
        self.status.configure(state="disabled")


