        # Preview section
        prev_card = _card(self, "Preview  (categories that will be created)")
        self.cat_frame = ctk.CTkFrame(prev_card, fg_color="transparent")
        self.cat_frame.pack(fill="x", padx=16, pady=8)
        cols = 3
        for i, (cat, exts) in enumerate(self.CATEGORIES.items()):
            f = ctk.CTkFrame(self.cat_frame, fg_color=BG_INPUT, corner_radius=8)
            f.grid(row=i//cols, column=i%cols, padx=6, pady=6, sticky="ew")
            ctk.CTkLabel(f, text=cat, font=("Consolas", 11, "bold"),
                         text_color=GREEN).pack(anchor="w", padx=10, pady=(6,2))
            ctk.CTkLabel(f, text="  ".join(exts[:4]) + ("…" if len(exts)>4 else ""),
                         font=("Consolas", 9), text_color=TEXT_SEC).pack(anchor="w", padx=10, pady=(0,6))
        for c in range(cols): self.cat_frame.columnconfigure(c, weight=1)

        self.status = _log_box(self)

        ctk.CTkButton(self, text="⚡  Organize Now", fg_color=GREEN,
                      hover_color=GREEN_HOVER, text_color="#000",
                      font=("Consolas", 13, "bold"),
                      command=self._organize).pack(pady=12)

    def _browse(self):
        d = filedialog.askdirectory()
        if d: self.dir_var.set(d)

    def _organize(self):
        def task():
            directory = self.dir_var.get().strip()
            if not os.path.isdir(directory):
                self._log("✗  Not a valid directory."); return
            if not os.access(directory, os.W_OK):
                self._log("✗  Directory not writable."); return
            moved = 0
            for cat, exts in self.CATEGORIES.items():
                name = cat.split(" ", 1)[1]   # strip emoji for folder name
                matches = [f for f in os.listdir(directory)
                           if os.path.isfile(os.path.join(directory, f))
                           and os.path.splitext(f)[1].lower() in exts]
                if not matches: continue
                dest = os.path.join(directory, name)
                os.makedirs(dest, exist_ok=True)
                for fname in matches:
                    shutil.move(os.path.join(directory, fname), os.path.join(dest, fname))
                    self._log(f"  ↳ {fname}  →  {name}/")
                    moved += 1
            self._log(f"\n✓  Done! {moved} file(s) organized.")
        threading.Thread(target=task, daemon=True).start()

    def _log(self, msg):
        self.status.configure(state="normal")
        self.status.insert("end", msg + "\n")
        self.status.see("end")
        self.status.configure(state="disabled")


