def _panel_header(parent, icon, title, subtitle):
    hdr = ctk.CTkFrame(parent, fg_color="transparent")
    hdr.pack(fill="x", padx=32, pady=(32, 0))
    top = ctk.CTkFrame(hdr, fg_color="transparent")
