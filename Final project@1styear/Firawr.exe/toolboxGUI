# ─── Speech Recorder ──────────────────────────────────────────────────────────

class SpeechRecorderPanel(ctk.CTkFrame):
    def __init__(self, master):
        super().__init__(master, fg_color=BG_PANEL, corner_radius=0)
        self._build()

    def _build(self):
        _panel_header(self, "🎙", "Speech Recorder",
                      "Record from your microphone and save in multiple formats.")

        fmt_frame = _card(self, "Output Formats")
        self.fmt_vars = {}
        fmts = ["RAW", "WAV", "AIFF", "FLAC"]
        row = ctk.CTkFrame(fmt_frame, fg_color="transparent")
        row.pack(fill="x", padx=16, pady=8)
        for f in fmts:
            v = ctk.BooleanVar(value=True)
            self.fmt_vars[f] = v
            ctk.CTkCheckBox(row, text=f, variable=v,
                            fg_color=GREEN, hover_color=GREEN_HOVER).pack(side="left", padx=12)

        self.status = _log_box(self)

        btn_row = ctk.CTkFrame(self, fg_color="transparent")
        btn_row.pack(pady=12)
        ctk.CTkButton(btn_row, text="⏺  Start Recording", fg_color=GREEN,
                      hover_color=GREEN_HOVER, text_color="#000",
                      font=("Consolas", 13, "bold"),
                      command=self._record).pack(side="left", padx=8)

    def _record(self):
        def task():
            self._log("🎙  Recording for 5 seconds...")

        try:
            samplerate = 44100
            duration = 5

            recording = sd.rec(
                int(duration * samplerate),
                samplerate=samplerate,
                channels=1,
                dtype='int16'
            )

            sd.wait()

            temp_wav = "temp_recording.wav"
            sf.write(temp_wav, recording, samplerate)

        except Exception as e:
            self._log(f"✗  {e}")
            return

        self._log("✓  Captured. Saving files…")

        try:
            with open(temp_wav, "rb") as f:
                wav_data = f.read()

            if self.fmt_vars["WAV"].get():
                with open("microphone-results.wav", "wb") as f:
                    f.write(wav_data)
                self._log("  ✓  Saved → microphone-results.wav")

            try:
                from pydub import AudioSegment

                audio = AudioSegment.from_wav(temp_wav)

                if self.fmt_vars["RAW"].get():
                    with open("microphone-results.raw", "wb") as f:
                        f.write(audio.raw_data)
                    self._log("  ✓  Saved → microphone-results.raw")

                if self.fmt_vars["AIFF"].get():
                    audio.export("microphone-results.aiff", format="aiff")
                    self._log("  ✓  Saved → microphone-results.aiff")

                if self.fmt_vars["FLAC"].get():
                    audio.export("microphone-results.flac", format="flac")
                    self._log("  ✓  Saved → microphone-results.flac")

            except ImportError:
                self._log("✗  pip install pydub")

            if os.path.exists(temp_wav):
                os.remove(temp_wav)

        except Exception as e:
            self._log(f"✗  {e}")

        self._log("Done.")

        threading.Thread(target=task, daemon=True).start()

    def _log(self, msg):
        self.status.configure(state="normal")
        self.status.insert("end", msg + "\n")
        self.status.see("end")
        self.status.configure(state="disabled")


