class BudgetTrackerPanel(ctk.CTkFrame):
    def __init__(self, master):
        super().__init__(master, fg_color=BG_PANEL, corner_radius=0)
        self.conn = sqlite3.connect("firawr_budget.db")
        c = self.conn.cursor()
        c.execute("""CREATE TABLE IF NOT EXISTS transactions (
                        id INTEGER PRIMARY KEY AUTOINCREMENT,
                        date TEXT, description TEXT,
                        amount REAL, category TEXT)""")
        self.conn.commit()
        self._build()
        self._refresh()

    def _build(self):
        _panel_header(self, "💰", "Budget Tracker",
                      "Log income and expenses. Data stored locally in SQLite.")

        # Balance bar
        self.bal_frame = ctk.CTkFrame(self, fg_color=BG_CARD, corner_radius=10,
                                      border_width=1, border_color=BORDER)
        self.bal_frame.pack(fill="x", padx=32, pady=(0, 16))
        inner = ctk.CTkFrame(self.bal_frame, fg_color="transparent")
        inner.pack(padx=20, pady=12)
        self.bal_lbl    = ctk.CTkLabel(inner, text="Balance  $0.00",
                                        font=("Georgia", 20, "bold"), text_color=GREEN)
        self.bal_lbl.pack(side="left", padx=(0, 32))
