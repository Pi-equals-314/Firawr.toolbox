class CalculatorPanel(ctk.CTkFrame):
    def __init__(self, master):
        super().__init__(master, fg_color=BG_PANEL, corner_radius=0)
        self._expr = ""
        self._build()

    def _build(self):
        _panel_header(self, "🔢", "Calculator",
                      "Standard, scientific, and complex number arithmetic.")

        outer = ctk.CTkFrame(self, fg_color="transparent")
        outer.pack(expand=True)

        # Display
        disp_frame = ctk.CTkFrame(outer, fg_color=BG_CARD, corner_radius=12,
                                   border_width=1, border_color=BORDER, width=380)
        disp_frame.pack(pady=(0, 12))
        self.expr_lbl = ctk.CTkLabel(disp_frame, text="", font=("Consolas", 13),
                                      text_color=TEXT_SEC, anchor="e", width=360)
        self.expr_lbl.pack(padx=16, pady=(10, 0), anchor="e")
        self.disp = ctk.CTkLabel(disp_frame, text="0", font=("Georgia", 36, "bold"),
                                  text_color=TEXT_PRI, anchor="e", width=360)
        self.disp.pack(padx=16, pady=(0, 12), anchor="e")

        # Button grid
        btn_frame = ctk.CTkFrame(outer, fg_color="transparent")
        btn_frame.pack()

        layout = [
            ["C", "±", "%", "÷"],
            ["7", "8", "9", "×"],
            ["4", "5", "6", "−"],
            ["1", "2", "3", "+"],
            ["0", ".", "⌫", "="],
        ]

        for r, row in enumerate(layout):
            for c, lbl in enumerate(row):
                is_op  = lbl in ("÷", "×", "−", "+", "=")
                is_util= lbl in ("C", "±", "%", "⌫")
                color  = GREEN if is_op else (BG_INPUT if is_util else BG_CARD)
                hover  = GREEN_HOVER if is_op else BORDER
                tc     = "#000" if is_op else TEXT_PRI
                w = 360 // 4

                btn = ctk.CTkButton(btn_frame, text=lbl, width=w - 6, height=56,
                                    fg_color=color, hover_color=hover,
                                    text_color=tc, font=("Georgia", 18),
                                    corner_radius=8,
                                    command=lambda x=lbl: self._press(x))
                btn.grid(row=r, column=c, padx=3, pady=3)

        # Extra functions
        ext = ctk.CTkFrame(outer, fg_color="transparent")
        ext.pack(pady=(12, 0))
        for fn in ["√x", "x²", "1/x", "n!", "log", "sin", "cos", "tan"]:
            ctk.CTkButton(ext, text=fn, width=72, height=36,
                          fg_color=BG_CARD, hover_color=BORDER,
                          border_width=1, border_color=BORDER,
                          text_color=GREEN, font=("Consolas", 11),
                          command=lambda f=fn: self._fn(f)).pack(side="left", padx=3)

    def _press(self, k):
        import math
        op_map = {"÷": "/", "×": "*", "−": "-"}
        if k == "C":
            self._expr = ""; self._update("0")
        elif k == "⌫":
            self._expr = self._expr[:-1]; self._update(self._expr or "0")
        elif k == "=":
            try:
                expr = self._expr.replace("÷","/").replace("×","*").replace("−","-")
                result = eval(expr, {"__builtins__": {}}, {})
                self._update(str(result)); self.expr_lbl.configure(text=self._expr+" =")
                self._expr = str(result)
            except Exception:
                self._update("Error"); self._expr = ""
        elif k == "±":
            if self._expr.startswith("-"): self._expr = self._expr[1:]
            elif self._expr: self._expr = "-" + self._expr
            self._update(self._expr or "0")
        elif k == "%":
            try:
                self._expr = str(eval(self._expr, {"__builtins__": {}}, {}) / 100)
                self._update(self._expr)
            except: pass
        else:
            sym = op_map.get(k, k)
            self._expr += sym; self._update(self._expr)

    def _fn(self, fn):
        import math
        try:
            val = float(eval(self._expr or "0", {"__builtins__": {}}, {}))
            res = {
                "√x": math.sqrt(val), "x²": val**2, "1/x": 1/val,
                "n!": math.factorial(int(val)), "log": math.log10(val),
                "sin": math.sin(math.radians(val)),
                "cos": math.cos(math.radians(val)),
                "tan": math.tan(math.radians(val)),
            }[fn]
            self._expr = str(res); self._update(self._expr)
        except Exception as e:
            self._update("Error"); self._expr = ""

    def _update(self, val):
        display = val[-12:] if len(val) > 12 else val
        self.disp.configure(text=display or "0")
        if len(val) > 12: self.expr_lbl.configure(text=val)


