        # ── Input card ────────────────────────────────────────────────────
        card = _card(self, "URL Input")

        url_row = ctk.CTkFrame(card, fg_color="transparent")
        url_row.pack(fill="x", padx=16, pady=(8, 0))
        ctk.CTkLabel(url_row, text="Long URL", font=("Consolas", 11),
                     text_color=TEXT_SEC, width=90, anchor="w").pack(side="left")
        self.url_var = ctk.StringVar()
        ctk.CTkEntry(url_row, textvariable=self.url_var, width=400,
                     fg_color=BG_INPUT, border_color=BORDER, font=("Consolas", 11),
                     placeholder_text="https://example.com/very/long/url…").pack(side="left", padx=(0, 8))

        svc_row = ctk.CTkFrame(card, fg_color="transparent")
        svc_row.pack(fill="x", padx=16, pady=(6, 12))
        ctk.CTkLabel(svc_row, text="Service", font=("Consolas", 11),
                     text_color=TEXT_SEC, width=90, anchor="w").pack(side="left")
        self.svc_var = ctk.StringVar(value="TinyURL")
        ctk.CTkComboBox(svc_row, variable=self.svc_var,
                        values=list(self.SERVICES.keys()),
                        width=160, fg_color=BG_INPUT, border_color=BORDER,
                        button_color=GREEN, button_hover_color=GREEN_HOVER,
                        font=("Consolas", 11)).pack(side="left")

        # ── Result card ───────────────────────────────────────────────────
        res_card = _card(self, "Shortened URL")
        res_inner = ctk.CTkFrame(res_card, fg_color="transparent")
        res_inner.pack(fill="x", padx=16, pady=10)
        self.result_var = ctk.StringVar(value="—")
        result_entry = ctk.CTkEntry(res_inner, textvariable=self.result_var,
                                     width=400, fg_color=BG_INPUT, border_color=BORDER,
                                     font=("Consolas", 12), text_color=GREEN,
                                     state="readonly")
        result_entry.pack(side="left", padx=(0, 8))
        ctk.CTkButton(res_inner, text="📋 Copy", width=80, fg_color=BG_CARD,
                      hover_color=BORDER, border_width=1, border_color=BORDER,
                      text_color=TEXT_SEC, font=("Consolas", 11),
                      command=self._copy).pack(side="left")

        # ── Log ───────────────────────────────────────────────────────────
        self.status = _log_box(self)

        # ── Action ────────────────────────────────────────────────────────
        ctk.CTkButton(self, text="⚡  Shorten", fg_color=GREEN,
                      hover_color=GREEN_HOVER, text_color="#000",
                      font=("Consolas", 13, "bold"),
                      command=self._shorten).pack(pady=12)

    # ── Helpers ───────────────────────────────────────────────────────────

    @staticmethod
    def _validate_url(url: str) -> bool:
        pattern = re.compile(
            r'^https?://'
            r'(?:(?:[A-Z0-9](?:[A-Z0-9-]{0,61}[A-Z0-9])?\.)+[A-Z]{2,6}\.?|'
            r'localhost|\d{1,3}(?:\.\d{1,3}){3})'
            r'(?::\d+)?(?:/?|[/?]\S+)$', re.IGNORECASE)
        return bool(pattern.match(url))

    def _shorten(self):
        def task():
            try:
                import pyshorteners
            except ImportError:
                self._log("✗  pip install pyshorteners"); return

            raw = self.url_var.get().strip()
            if not raw:
                self._log("✗  Enter a URL first."); return
            if not self._validate_url(raw):
                self._log("✗  URL must start with http:// or https://"); return

            svc_name = self.svc_var.get()
            svc_key  = self.SERVICES.get(svc_name, "tinyurl")
            self._log(f"Shortening via {svc_name}…")
            try:
                s       = pyshorteners.Shortener()
                short   = getattr(s, svc_key).short(raw)
                self.result_var.set(short)
                self._log(f"✓  {short}")
            except Exception as e:
                self._log(f"✗  {e}")
        threading.Thread(target=task, daemon=True).start()

    def _copy(self):
        val = self.result_var.get()
        if val and val != "—":
            self.clipboard_clear()
            self.clipboard_append(val)
            self._log("📋  Copied to clipboard.")

    def _log(self, msg):
        self.status.configure(state="normal")
        self.status.insert("end", msg + "\n")
        self.status.see("end")
        self.status.configure(state="disabled")


