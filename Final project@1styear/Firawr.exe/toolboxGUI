class URLShortenerPanel(ctk.CTkFrame):
    """
    Self-contained URL shortener using pyshorteners.
    Original tool depended on internal app.models / app.services modules that
    cannot be shipped standalone, so this reimplements the same contract
    (validate URL → shorten → display result) using the pyshorteners library.

    pip install pyshorteners
    """

    SERVICES = {
        "TinyURL":  "tinyurl",
        "Dagd":     "dagd",
        "Clckru":   "clckru",
        "Isgd":     "isgd",
    }

    def __init__(self, master):
        super().__init__(master, fg_color=BG_PANEL, corner_radius=0)
        self._build()

    def _build(self):
        _panel_header(self, "🔗", "URL Shortener",
