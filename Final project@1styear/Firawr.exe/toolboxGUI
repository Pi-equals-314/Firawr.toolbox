# ─── Speech Recorder ──────────────────────────────────────────────────────────

class SpeechRecorderPanel(ctk.CTkFrame):
    def __init__(self, master):
        super().__init__(master, fg_color=BG_PANEL, corner_radius=0)
        self._build()

    def _build(self):
        _panel_header(self, "🎙", "Speech Recorder",
                      "Record from your microphone and save in multiple formats.")

        # Format selection
        fmt_frame = _card(self, "Output Formats")
        self.fmt_vars = {}
        fmts = ["RAW", "WAV", "AIFF", "FLAC"]
        row = ctk.CTkFrame(fmt_frame, fg_color="transparent")
        row.pack(fill="x", padx=16, pady=8)
        for f in fmts:
            v = ctk.BooleanVar(value=True)
            self.fmt_vars[f] = v
            ctk.CTkCheckBox(row, text=f, variable=v,
                            fg_color=GREEN, hover_color=GREEN_HOVER).pack(side="left", padx=12)

        # Status box
        self.status = _log_box(self)

        # Buttons
        btn_row = ctk.CTkFrame(self, fg_color="transparent")
        btn_row.pack(pady=12)
        ctk.CTkButton(btn_row, text="⏺  Start Recording", fg_color=GREEN,
                      hover_color=GREEN_HOVER, text_color="#000",
                      font=("Consolas", 13, "bold"),
                      command=self._record).pack(side="left", padx=8)

    def _record(self):
        def task():
            self._log("Importing speech_recognition…")
            try:
                import speech_recognition as sr
            except ImportError:
                self._log("✗  pip install SpeechRecognition pyaudio"); return
            r = sr.Recognizer()
            self._log("🎙  Listening — speak now…")
            try:
                with sr.Microphone() as src:
                    audio = r.listen(src)
            except Exception as e:
                self._log(f"✗  {e}"); return
            self._log("✓  Captured. Saving files…")
            mapping = {
                "RAW":  ("microphone-results.raw",  audio.get_raw_data),
                "WAV":  ("microphone-results.wav",  audio.get_wav_data),
                "AIFF": ("microphone-results.aiff", audio.get_aiff_data),
                "FLAC": ("microphone-results.flac", audio.get_flac_data),
            }
            for fmt, (fname, getter) in mapping.items():
                if self.fmt_vars[fmt].get():
                    with open(fname, "wb") as f: f.write(getter())
                    self._log(f"  ✓  Saved → {fname}")
            self._log("Done.")
        threading.Thread(target=task, daemon=True).start()

    def _log(self, msg):
        self.status.configure(state="normal")
        self.status.insert("end", msg + "\n")
        self.status.see("end")
        self.status.configure(state="disabled")


